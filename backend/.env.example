# Copy this to .env and fill in your values

# PostgreSQL — get free DB from https://supabase.com or https://railway.app
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/resume_tracker?schema=public"

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# Anthropic Claude API — get from https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-..."

# Server
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL="http://localhost:3000"
